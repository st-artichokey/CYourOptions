<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CYourOptions.App.ViewModels"
             x:Class="CYourOptions.App.Views.GamePage"
             Title="CYourOptions">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <!-- Node Title -->
            <Label
                Text="{Binding Title}"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalOptions="Start" />

            <!-- Node Text -->
            <Label
                Text="{Binding Text}"
                FontSize="16"
                LineBreakMode="WordWrap"
                HorizontalOptions="Start" />

            <!-- Separator -->
            <BoxView
                HeightRequest="1"
                Color="{StaticResource Gray300}"
                Margin="0,10" />

            <!-- Choice Buttons -->
            <VerticalStackLayout
                IsVisible="{Binding ShowChoices}"
                Spacing="12"
                BindableLayout.ItemsSource="{Binding Choices}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Button
                            Text="{Binding Label}"
                            Command="{Binding SelectCommand}"
                            CommandParameter="{Binding Index}"
                            HorizontalOptions="Fill"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            FontSize="14"
                            Padding="16,12" />
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <!-- End Node Actions -->
            <VerticalStackLayout
                IsVisible="{Binding IsEndNode}"
                Spacing="12"
                Margin="0,20,0,0">

                <Label
                    Text="The End"
                    FontSize="22"
                    FontAttributes="Italic"
                    HorizontalOptions="Center"
                    TextColor="{StaticResource Gray500}" />

                <Button
                    Text="Play Again"
                    Command="{Binding RestartCommand}"
                    HorizontalOptions="Center"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    FontSize="16"
                    Padding="24,12" />
            </VerticalStackLayout>

            <!-- Back Button -->
            <Button
                Text="← Go Back"
                Command="{Binding GoBackCommand}"
                IsVisible="{Binding CanGoBack}"
                HorizontalOptions="Start"
                BackgroundColor="Transparent"
                TextColor="{StaticResource Primary}"
                FontSize="14"
                Margin="0,10,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
